# ── Teleprogreso S.A. — Variables de entorno ─────────────────────────────
# Copiar como .env y ajustar valores según el entorno

# --- Base de datos (PostgreSQL) ---
# Para desarrollo local (sin Docker):
DATABASE_URL=postgresql+psycopg2://teleprogreso:teleprogreso@localhost:5432/teleprogreso
# Para Docker (el host es el nombre del servicio "db"):
# DATABASE_URL=postgresql+psycopg2://teleprogreso:teleprogreso@db:5432/teleprogreso

# --- Seguridad JWT ---
# Generar una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-por-clave-larga-en-produccion

# --- Configuración JWT (opcionales, tienen defaults en config.py) ---
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=1440
