# Opción A (recomendada para probar en Windows sin Docker): deja esta línea o bórrala (el código ya usa SQLite por defecto).
DATABASE_URL=sqlite:///./teleprogreso.db

# Opción B (PostgreSQL con Docker): comenta la de arriba y usa esta cuando `docker compose up -d` esté corriendo.
# DATABASE_URL=postgresql+psycopg2://teleprogreso:teleprogreso@localhost:5432/teleprogreso

SECRET_KEY=cambiar-por-clave-larga-en-produccion
